{
  "name": "vl4ai-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "astro dev",
    "lint": "pnpm exec tsc --noEmit && node scripts/validate-source-links.mjs",
    "check": "astro check",
    "build": "astro build",
    "preview": "node scripts/preview-dist.mjs",
    "e2e": "pnpm test:e2e",
    "verify:dist-links": "node scripts/validate-dist-links.mjs",
    "test:e2e": "pnpm verify:dist-links && playwright test",
    "verify": "pnpm lint && pnpm astro check && pnpm build && pnpm test:e2e"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/sitemap": "^3.7.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "astro": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3"
  }
}
