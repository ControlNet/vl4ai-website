---
import ButtonLink from '../ui/ButtonLink.astro';
import CardSurface from '../ui/CardSurface.astro';
import SectionHeading from '../ui/SectionHeading.astro';

interface NewsPreviewItem {
  slug: string;
  title: string;
  summary: string;
  dateLabel: string;
  imageUrl: string;
  imageAlt: string;
  href: string;
  external: boolean;
}

interface Props {
  description: string;
  items: NewsPreviewItem[];
}

const { description, items } = Astro.props as Props;
---

<div class="homepage-section-stack">
  <div class="home-news__header">
    <SectionHeading
      eyebrow="Updates"
      title="Latest"
      accent="news"
      description={description}
    />

    <ButtonLink href="/news/" variant="secondary" class="home-news__archive-cta" testId="home-news-archive-cta">
      Explore Archive
    </ButtonLink>
  </div>

  {
    items.length > 0 ? (
      <div class="home-news__grid" aria-label="Latest news preview">
        {items.map((item) => (
          <article
            class="home-news__item"
            data-testid="news-preview-item"
            data-news-slug={item.slug}
          >
            <CardSurface variant="outlined" class="home-news__surface">
              <a
                href={item.href}
                class="home-news__link"
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer' : undefined}
              >
                <div class="home-news__media">
                  <img src={item.imageUrl} alt={item.imageAlt} loading="lazy" />
                  <p class="home-news__date">{item.dateLabel}</p>
                </div>

                <div class="home-news__content">
                  <h3 class="home-news__title">{item.title}</h3>
                  <p class="home-news__summary">{item.summary}</p>
                  <p class="home-news__cta">Read update <span aria-hidden="true">↗</span></p>
                </div>
              </a>
            </CardSurface>
          </article>
        ))}
      </div>
    ) : (
      <CardSurface variant="dashed" class="home-news__empty-state" testId="home-news-empty-state">
        <p class="eyebrow-label">News collection</p>
        <h3 class="primitive-card__title">No featured updates yet</h3>
        <p class="primitive-card__copy">Homepage previews will appear here once news entries are marked for homepage display in the collection.</p>
      </CardSurface>
    )
  }
</div>

<style>
  .home-news__header {
    display: grid;
    gap: var(--space-8);
    align-items: end;
  }

  .home-news__header :global(.section-heading) {
    margin-bottom: 0;
  }

  .home-news__archive-cta {
    justify-self: start;
  }

  .home-news__grid {
    display: grid;
    gap: var(--space-8);
  }

  .home-news__item {
    min-width: 0;
  }

  .home-news__surface,
  .home-news__link,
  .home-news__content {
    display: grid;
  }

  .home-news__surface,
  .home-news__content {
    gap: var(--space-6);
  }

  .home-news__surface {
    height: 100%;
    padding: var(--space-5);
  }

  .home-news__link {
    height: 100%;
    gap: var(--space-6);
  }

  .home-news__media {
    position: relative;
    overflow: hidden;
    border-radius: calc(var(--radius-2xl) - var(--space-1));
    aspect-ratio: 4 / 5;
    background: var(--color-gray-100);
  }

  .home-news__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
    transition:
      transform var(--duration-slow) var(--ease-standard),
      filter var(--duration-slow) var(--ease-standard);
  }

  .home-news__item:hover .home-news__media img {
    transform: scale(1.06);
    filter: grayscale(0);
  }

  .home-news__date {
    position: absolute;
    inset: var(--space-6) auto auto var(--space-6);
    display: inline-flex;
    align-items: center;
    margin: 0;
    border-radius: var(--radius-pill);
    background: rgb(255 255 255 / 0.92);
    padding: var(--space-2) var(--space-4);
    color: var(--color-gray-900);
    font-size: var(--text-tiny);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    box-shadow: var(--shadow-sm);
  }

  .home-news__title,
  .home-news__summary,
  .home-news__cta {
    margin: 0;
  }

  .home-news__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    transition: color var(--duration-base) var(--ease-standard);
  }

  .home-news__item:hover .home-news__title {
    color: var(--color-blue-800);
  }

  .home-news__summary {
    color: var(--color-gray-500);
    font-size: var(--text-sm);
    font-weight: var(--weight-light);
    line-height: var(--line-height-sm);
  }

  .home-news__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-gray-400);
    font-size: var(--text-tiny);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    transition: color var(--duration-base) var(--ease-standard);
  }

  .home-news__item:hover .home-news__cta {
    color: var(--color-monash-blue);
  }

  .home-news__empty-state {
    padding: var(--space-8);
  }

  @media (min-width: 48rem) {
    .home-news__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .home-news__header {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .home-news__archive-cta {
      justify-self: end;
    }

    .home-news__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
