---
import CardSurface from '../ui/CardSurface.astro';
import SectionHeading from '../ui/SectionHeading.astro';

interface ResearchTopicSummary {
  slug: string;
  title: string;
}

interface ResearchPillar {
  category: string;
  title: string;
  description: string;
  topicCount: number;
  topics: ResearchTopicSummary[];
  imageUrl: string;
  imageAlt: string;
  orientation: 'default' | 'reverse';
}

interface BenchmarkLink {
  slug: string;
  title: string;
  href: string;
  external: boolean;
}

interface BenchmarkSpotlight extends BenchmarkLink {
  description: string;
  imageUrl: string;
  imageAlt: string;
}

interface Props {
  description: string;
  pillars: ResearchPillar[];
  benchmarkSpotlight: BenchmarkSpotlight;
  benchmarkLinks: BenchmarkLink[];
}

const { description, pillars, benchmarkSpotlight, benchmarkLinks } = Astro.props as Props;
const benchmarkCatalogueLabel =
  benchmarkLinks.length === 1 ? '1 more benchmark in the catalogue' : `${benchmarkLinks.length} more benchmarks in the catalogue`;
---

<div class="homepage-section-stack">
  <SectionHeading
    eyebrow="Research"
    title="Research"
    accent="program"
    description={description}
  />

  <div class="research-section" data-testid="research-section">
    <div class="research-pillars">
      {
        pillars.map((pillar) => (
          <article class:list={['research-pillar', pillar.orientation === 'reverse' && 'research-pillar--reverse']} data-testid="research-pillar">
            <div class="research-pillar__copy">
              <div class="research-pillar__meta">
                <p class="eyebrow-label">{pillar.category}</p>
                <p class="research-pillar__count">{pillar.topicCount} focus {pillar.topicCount === 1 ? 'area' : 'areas'}</p>
              </div>

              <h3 class="research-pillar__title">{pillar.title}</h3>
              <p class="research-pillar__description">{pillar.description}</p>

              <ul class="research-topic-list" aria-label={`${pillar.title} subtopics`}>
                {pillar.topics.map((topic) => (
                  <li>
                    <span class="research-topic-pill">{topic.title}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="research-pillar__media">
              <CardSurface variant="elevated" class="research-pillar__media-shell">
                <div class="research-pillar__media-frame">
                  <img src={pillar.imageUrl} alt={pillar.imageAlt} loading="lazy" />
                </div>
              </CardSurface>
            </div>
          </article>
        ))
      }
    </div>

    <CardSurface variant="impact" class="benchmark-spotlight" testId="benchmark-spotlight">
      <div class="benchmark-spotlight__grid">
        <div class="benchmark-spotlight__content">
          <p class="benchmark-spotlight__eyebrow">Dataset spotlight</p>
          <h3 class="benchmark-spotlight__title">{benchmarkSpotlight.title}</h3>
          <p class="benchmark-spotlight__description">{benchmarkSpotlight.description}</p>

          <div class="benchmark-spotlight__actions">
            <a
              href={benchmarkSpotlight.href}
              class="button-link button-link--secondary"
              target={benchmarkSpotlight.external ? '_blank' : undefined}
              rel={benchmarkSpotlight.external ? 'noreferrer' : undefined}
              data-testid="benchmark-spotlight-cta"
            >
              Visit benchmark
            </a>
          </div>

          {benchmarkLinks.length > 0 && (
            <div class="benchmark-catalogue">
              <div class="benchmark-catalogue__heading">
                <p class="micro-copy">Additional highlights</p>
                <p class="benchmark-catalogue__summary">{benchmarkCatalogueLabel}</p>
              </div>

              <ul class="benchmark-catalogue__list" aria-label="Research benchmarks and datasets">
                {benchmarkLinks.map((benchmarkLink) => (
                  <li>
                    <a
                      href={benchmarkLink.href}
                      class="benchmark-catalogue__link"
                      target={benchmarkLink.external ? '_blank' : undefined}
                      rel={benchmarkLink.external ? 'noreferrer' : undefined}
                      data-testid={`research-benchmark-link-${benchmarkLink.slug}`}
                    >
                      <span>{benchmarkLink.title}</span>
                      <span aria-hidden="true">↗</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <div class="benchmark-spotlight__media">
          <img src={benchmarkSpotlight.imageUrl} alt={benchmarkSpotlight.imageAlt} loading="lazy" />
        </div>
      </div>
    </CardSurface>
  </div>
</div>

<style>
  .research-section {
    display: grid;
    gap: var(--space-16);
  }

  .research-pillars {
    display: grid;
    gap: var(--space-12);
  }

  .research-pillar {
    display: grid;
    gap: var(--space-8);
    align-items: center;
    padding-top: var(--space-10);
    border-top: var(--border-subtle);
  }

  .research-pillar:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .research-pillar__copy {
    display: grid;
    gap: var(--space-5);
    min-width: 0;
  }

  .research-pillar__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .research-pillar__count {
    margin: 0;
    color: var(--color-gray-400);
    font-size: var(--text-tiny);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .research-pillar__title {
    margin: 0;
    font-size: var(--text-4xl);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: var(--line-height-4xl);
    text-transform: uppercase;
  }

  .benchmark-spotlight__title {
    margin: 0;
    font-size: clamp(var(--text-4xl), 5vw, var(--text-5xl));
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tighter);
    line-height: 1;
    text-transform: uppercase;
  }

  .research-pillar__description,
  .benchmark-spotlight__description {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: var(--weight-light);
    line-height: var(--leading-copy);
  }

  .research-pillar__description {
    color: var(--color-gray-600);
  }

  .benchmark-spotlight__description,
  .benchmark-catalogue__summary {
    color: var(--color-blue-100);
  }

  .research-topic-list,
  .benchmark-catalogue__list {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .research-topic-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .research-topic-pill {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    background: var(--color-gray-100);
    padding: var(--space-2) var(--space-4);
    color: var(--color-gray-900);
    font-size: var(--text-tiny);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .research-pillar__media {
    position: relative;
    min-width: 0;
  }

  .research-pillar__media::before {
    content: '';
    position: absolute;
    inset: var(--space-4) calc(var(--space-4) * -1) calc(var(--space-4) * -1) var(--space-4);
    border-radius: var(--radius-4xl);
    background: var(--color-blue-50);
    z-index: 0;
  }

  .research-pillar--reverse .research-pillar__media::before {
    inset: var(--space-4) var(--space-4) calc(var(--space-4) * -1) calc(var(--space-4) * -1);
  }

  .research-section :global(.research-pillar__media-shell) {
    position: relative;
    z-index: 1;
    padding: var(--space-4);
  }

  .research-pillar__media-frame,
  .benchmark-spotlight__media {
    overflow: hidden;
    border-radius: calc(var(--radius-3xl) - var(--space-1));
    background: var(--color-gray-100);
  }

  .research-pillar__media-frame {
    aspect-ratio: 16 / 11;
  }

  .research-pillar__media-frame img,
  .benchmark-spotlight__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform var(--duration-slow) var(--ease-standard),
      filter var(--duration-slow) var(--ease-standard);
  }

  .research-pillar:hover .research-pillar__media-frame img,
  .benchmark-spotlight:hover .benchmark-spotlight__media img {
    transform: scale(1.04);
  }

  .research-section :global(.benchmark-spotlight) {
    padding: var(--space-8);
  }

  .benchmark-spotlight__grid,
  .benchmark-spotlight__content,
  .benchmark-catalogue,
  .benchmark-catalogue__heading,
  .benchmark-catalogue__list {
    display: grid;
    gap: var(--space-6);
  }

  .benchmark-spotlight__eyebrow {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    margin: 0;
    border-radius: var(--radius-lg);
    background: var(--color-blue-700);
    padding: var(--space-2) var(--space-6);
    color: var(--color-white);
    font-size: var(--text-tiny);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .benchmark-spotlight__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .benchmark-catalogue__summary,
  .benchmark-catalogue__link {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-copy);
  }

  .benchmark-catalogue__list {
    gap: var(--space-3);
  }

  .benchmark-catalogue__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border: var(--border-dark);
    border-radius: var(--radius-2xl);
    background: var(--color-gray-900);
    color: var(--color-white);
    font-weight: var(--weight-medium);
    transition:
      background-color var(--duration-base) var(--ease-standard),
      transform var(--duration-base) var(--ease-standard);
  }

  .benchmark-catalogue__link:hover {
    background: var(--monash-blue);
    transform: translateY(calc(var(--space-1) * -1));
  }

  .benchmark-spotlight__media {
    min-height: 100%;
    box-shadow: var(--shadow-2xl);
  }

  .benchmark-spotlight__media img {
    filter: grayscale(1);
  }

  :global(.benchmark-spotlight):hover .benchmark-spotlight__media img {
    filter: grayscale(0);
  }

  @media (min-width: 64rem) {
    .research-pillar,
    .benchmark-spotlight__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-12);
    }

    .research-pillar--reverse .research-pillar__copy {
      order: 2;
    }

    .research-pillar--reverse .research-pillar__media {
      order: 1;
    }
  }
</style>
