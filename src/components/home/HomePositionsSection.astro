---
import CardSurface from '../ui/CardSurface.astro';

interface PositionLink {
  label: string;
  href: string;
  external: boolean;
  kind: string;
}

interface PositionOpeningCard {
  slug: string;
  title: string;
  positionTypeLabel: string;
  status: 'open' | 'closed' | 'archived';
  statusLabel: string;
  shortDescription: string;
  employmentType?: string;
  location?: string;
  duration?: string;
  primaryLink?: PositionLink;
  links: PositionLink[];
}

interface Props {
  overviewLabel: string;
  description: string;
  essentialSkills: string[];
  desirableSkills: string[];
  importantLinks: PositionLink[];
  inclusiveStatement: string;
  phdAvailabilityMessage: string;
  staffAvailabilityMessage: string;
  phdOpenings: PositionOpeningCard[];
  staffOpenings: PositionOpeningCard[];
}

const {
  overviewLabel,
  description,
  essentialSkills,
  desirableSkills,
  importantLinks,
  inclusiveStatement,
  phdAvailabilityMessage,
  staffAvailabilityMessage,
  phdOpenings,
  staffOpenings,
} = Astro.props as Props;

const getSurfaceVariant = (status: PositionOpeningCard['status']) => {
  if (status === 'open') {
    return 'elevated';
  }

  if (status === 'archived') {
    return 'muted';
  }

  return 'outlined';
};

const getPrimaryActionVariant = (status: PositionOpeningCard['status']) => (status === 'open' ? 'primary' : 'secondary');
---

<div class="homepage-section-stack positions-section-shell">
  <div class="positions-section" data-testid="positions-section">
    <header class="positions-hero">
      <div class="positions-hero__copy">
        <p class="section-heading__eyebrow">{overviewLabel}</p>
        <h2 class="positions-hero__title">
          Join our <span>mission</span>
        </h2>
        <p class="positions-hero__description">{description}</p>
      </div>
    </header>

    <section class="positions-group" aria-labelledby="positions-phd-heading">
      <div class="positions-group__heading">
        <h3 id="positions-phd-heading">PhD Positions</h3>
      </div>

      <div class="positions-group__grid">
        <div class="positions-guidance">
          <CardSurface variant="muted" class="positions-guidance-card positions-guidance-card--skills">
            <p class="eyebrow-label">Essential skills</p>
            <ul class="positions-list" aria-label="Essential PhD recruitment skills">
              {essentialSkills.map((skill) => (
                <li class="positions-list__item">
                  <span class="positions-list__dot" aria-hidden="true">✓</span>
                  <span>{skill}</span>
                </li>
              ))}
            </ul>
          </CardSurface>

          {
            desirableSkills.length > 0 && (
              <CardSurface variant="outlined" class="positions-guidance-card">
                <p class="eyebrow-label">Desirable skills</p>
                <ul class="positions-list" aria-label="Desirable PhD recruitment skills">
                  {desirableSkills.map((skill) => (
                    <li class="positions-list__item positions-list__item--muted">
                      <span class="positions-list__dot positions-list__dot--muted" aria-hidden="true">+</span>
                      <span>{skill}</span>
                    </li>
                  ))}
                </ul>
              </CardSurface>
            )
          }

          {
            importantLinks.length > 0 && (
              <CardSurface variant="outlined" class="positions-guidance-card positions-guidance-card--links">
                <div class="positions-guidance-card__header">
                  <p class="eyebrow-label">Important links</p>
                  <p class="micro-copy">Application and program details</p>
                </div>

                <div class="positions-link-list" aria-label="Important recruitment links">
                  {importantLinks.map((link) => (
                    <a
                      href={link.href}
                      class="positions-link-chip"
                      target={link.external ? '_blank' : undefined}
                      rel={link.external ? 'noreferrer' : undefined}
                    >
                      <span>{link.label}</span>
                      <span aria-hidden="true">↗</span>
                    </a>
                  ))}
                </div>
              </CardSurface>
            )
          }
        </div>

        <div class="positions-openings-cluster">
          <div class="positions-openings-cluster__header">
            <h4>Current opportunities</h4>
            <p>{phdAvailabilityMessage}</p>
          </div>

          {
            phdOpenings.length > 0 ? (
              <div class="positions-card-list" aria-label="PhD openings">
                {phdOpenings.map((opening) => (
                  <article
                    class:list={['position-card-shell', `position-card-shell--${opening.status}`]}
                    data-testid="position-card"
                    data-position-slug={opening.slug}
                    data-position-status={opening.status}
                  >
                    <CardSurface variant={getSurfaceVariant(opening.status)} class:list={['position-card', `position-card--${opening.status}`]}>
                      <div class="position-card__header">
                        <span
                          class:list={['position-status-chip', `position-status-chip--${opening.status}`]}
                          data-testid="position-status-chip"
                          data-position-status={opening.status}
                        >
                          {opening.statusLabel}
                        </span>
                        <p class="position-card__type">{opening.positionTypeLabel}</p>
                      </div>

                      <div class="position-card__copy">
                        <h5 class="position-card__title">{opening.title}</h5>
                        <p class="position-card__summary">{opening.shortDescription}</p>
                      </div>

                      <dl class="position-card__meta" aria-label={`${opening.title} metadata`}>
                        {
                          opening.employmentType && (
                            <div class="position-card__meta-item">
                              <dt>Employment</dt>
                              <dd>{opening.employmentType}</dd>
                            </div>
                          )
                        }
                        {
                          opening.location && (
                            <div class="position-card__meta-item">
                              <dt>Location</dt>
                              <dd>{opening.location}</dd>
                            </div>
                          )
                        }
                        {
                          opening.duration && (
                            <div class="position-card__meta-item">
                              <dt>Duration</dt>
                              <dd>{opening.duration}</dd>
                            </div>
                          )
                        }
                      </dl>

                      {(opening.primaryLink || opening.links.length > 0) && (
                        <div class="position-card__actions" aria-label={`${opening.title} links`}>
                          {opening.primaryLink && (
                            <a
                              href={opening.primaryLink.href}
                              class:list={['button-link', `button-link--${getPrimaryActionVariant(opening.status)}`, 'position-card__primary-action']}
                              target={opening.primaryLink.external ? '_blank' : undefined}
                              rel={opening.primaryLink.external ? 'noreferrer' : undefined}
                            >
                              {opening.primaryLink.label}
                            </a>
                          )}

                          {opening.links.map((link) => (
                            <a
                              href={link.href}
                              class="position-link-chip"
                              target={link.external ? '_blank' : undefined}
                              rel={link.external ? 'noreferrer' : undefined}
                            >
                              <span>{link.label}</span>
                              <span aria-hidden="true">↗</span>
                            </a>
                          ))}
                        </div>
                      )}
                    </CardSurface>
                  </article>
                ))}
              </div>
            ) : (
              <CardSurface variant="dashed" class="positions-empty-state">
                <p class="eyebrow-label">PhD openings</p>
                <h5 class="primitive-card__title">No published PhD opportunities yet</h5>
                <p class="primitive-card__copy">Open PhD calls will appear here as soon as they are recorded in the positions collection.</p>
              </CardSurface>
            )
          }
        </div>
      </div>
    </section>

    <div class="positions-separator" aria-hidden="true"></div>

    <section class="positions-group positions-group--staff" aria-labelledby="positions-staff-heading">
      <div class="positions-group__heading positions-group__heading--end">
        <h3 id="positions-staff-heading">
          Research <span>Staff</span>
        </h3>
      </div>

      <div class="positions-staff-overview">
        <div class="positions-staff-overview__copy">
          <h4>Current available staff positions</h4>
          <p>{staffAvailabilityMessage}</p>
        </div>

        <CardSurface variant="muted" class="positions-inclusion-card">
          <p class="positions-inclusion-card__quote">“{inclusiveStatement}”</p>
          <p class="positions-inclusion-card__label">Inclusive research environment</p>
        </CardSurface>
      </div>

      {
        staffOpenings.length > 0 ? (
          <div class="positions-card-list positions-card-list--staff" aria-label="Research staff openings">
            {staffOpenings.map((opening) => (
              <article
                class:list={['position-card-shell', `position-card-shell--${opening.status}`]}
                data-testid="position-card"
                data-position-slug={opening.slug}
                data-position-status={opening.status}
              >
                <CardSurface variant={getSurfaceVariant(opening.status)} class:list={['position-card', `position-card--${opening.status}`]}>
                  <div class="position-card__header">
                    <span
                      class:list={['position-status-chip', `position-status-chip--${opening.status}`]}
                      data-testid="position-status-chip"
                      data-position-status={opening.status}
                    >
                      {opening.statusLabel}
                    </span>
                    <p class="position-card__type">{opening.positionTypeLabel}</p>
                  </div>

                  <div class="position-card__copy">
                    <h5 class="position-card__title">{opening.title}</h5>
                    <p class="position-card__summary">{opening.shortDescription}</p>
                  </div>

                  <dl class="position-card__meta" aria-label={`${opening.title} metadata`}>
                    {
                      opening.employmentType && (
                        <div class="position-card__meta-item">
                          <dt>Employment</dt>
                          <dd>{opening.employmentType}</dd>
                        </div>
                      )
                    }
                    {
                      opening.location && (
                        <div class="position-card__meta-item">
                          <dt>Location</dt>
                          <dd>{opening.location}</dd>
                        </div>
                      )
                    }
                    {
                      opening.duration && (
                        <div class="position-card__meta-item">
                          <dt>Duration</dt>
                          <dd>{opening.duration}</dd>
                        </div>
                      )
                    }
                  </dl>

                  {(opening.primaryLink || opening.links.length > 0) && (
                    <div class="position-card__actions" aria-label={`${opening.title} links`}>
                      {opening.primaryLink && (
                        <a
                          href={opening.primaryLink.href}
                          class:list={['button-link', `button-link--${getPrimaryActionVariant(opening.status)}`, 'position-card__primary-action']}
                          target={opening.primaryLink.external ? '_blank' : undefined}
                          rel={opening.primaryLink.external ? 'noreferrer' : undefined}
                        >
                          {opening.primaryLink.label}
                        </a>
                      )}

                      {opening.links.map((link) => (
                        <a
                          href={link.href}
                          class="position-link-chip"
                          target={link.external ? '_blank' : undefined}
                          rel={link.external ? 'noreferrer' : undefined}
                        >
                          <span>{link.label}</span>
                          <span aria-hidden="true">↗</span>
                        </a>
                      ))}
                    </div>
                  )}
                </CardSurface>
              </article>
            ))}
          </div>
        ) : (
          <CardSurface variant="dashed" class="positions-empty-state">
            <p class="eyebrow-label">Research staff</p>
            <h5 class="primitive-card__title">No research-staff openings are published</h5>
            <p class="primitive-card__copy">Research-assistant, engineer, and fellow roles will appear here once they are recorded in the positions collection.</p>
          </CardSurface>
        )
      }
    </section>
  </div>
</div>

<style>
  .positions-section-shell,
  .positions-section,
  .positions-hero,
  .positions-hero__copy,
  .positions-group,
  .positions-guidance,
  .positions-guidance-card,
  .positions-openings-cluster,
  .positions-openings-cluster__header,
  .positions-card-list,
  .position-card,
  .position-card__copy,
  .position-card__meta,
  .position-card__actions,
  .positions-staff-overview,
  .positions-staff-overview__copy,
  .positions-inclusion-card,
  .positions-guidance-card__header {
    display: grid;
    gap: var(--space-6);
  }

  .positions-section {
    gap: var(--space-16);
  }

  .positions-hero {
    gap: var(--space-8);
    padding-bottom: var(--space-2);
  }

  .positions-hero__title,
  .positions-group__heading h3 {
    margin: 0;
    font-weight: var(--weight-black);
    line-height: var(--leading-none);
    letter-spacing: var(--tracking-tighter);
    text-transform: uppercase;
  }

  .positions-hero__title {
    font-size: clamp(var(--text-5xl), 8vw, var(--text-8xl));
  }

  .positions-hero__title span,
  .positions-group__heading h3 span {
    color: var(--color-gray-300);
  }

  .positions-hero__description,
  .positions-openings-cluster__header p,
  .positions-staff-overview__copy p,
  .positions-inclusion-card__quote,
  .position-card__summary,
  .positions-list__item,
  .position-card__meta-item dd {
    margin: 0;
    color: var(--color-gray-600);
    font-size: var(--text-base);
    font-weight: var(--weight-light);
    line-height: var(--leading-copy);
  }

  .positions-hero__description {
    max-width: 48rem;
    font-size: var(--text-lg);
  }

  .positions-group {
    gap: var(--space-10);
  }

  .positions-group__heading h3 {
    font-size: clamp(var(--text-4xl), 5vw, var(--text-5xl));
  }

  .positions-group__heading--end {
    text-align: left;
  }

  .positions-group__grid {
    display: grid;
    gap: var(--space-10);
    align-items: start;
  }

  .positions-guidance-card,
  .positions-empty-state,
  .position-card,
  .positions-inclusion-card {
    padding: var(--space-6);
  }

  .positions-guidance-card--skills {
    background: var(--color-gray-50);
  }

  .positions-list {
    display: grid;
    gap: var(--space-4);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .positions-list__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .positions-list__item--muted {
    color: var(--color-gray-500);
  }

  .positions-list__dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex: 0 0 1.5rem;
    border-radius: var(--radius-pill);
    background: var(--color-blue-50);
    color: var(--color-monash-blue);
    font-size: var(--text-tiny);
    font-weight: var(--weight-black);
    line-height: var(--leading-none);
    margin-top: var(--space-1);
  }

  .positions-list__dot--muted {
    background: var(--color-gray-100);
    color: var(--color-gray-500);
  }

  .positions-guidance-card__header .micro-copy,
  .position-card__type,
  .position-card__meta-item dt,
  .positions-inclusion-card__label {
    margin: 0;
    font-size: var(--text-tiny);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .positions-guidance-card__header .micro-copy,
  .position-card__type,
  .position-card__meta-item dt {
    color: var(--color-gray-400);
  }

  .positions-link-list,
  .position-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .positions-link-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    border: var(--border-subtle);
    border-radius: var(--radius-pill);
    background: var(--color-white);
    padding: var(--space-2) var(--space-4);
    color: var(--color-gray-500);
    font-size: var(--text-tiny);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    transition:
      border-color var(--duration-base) var(--ease-standard),
      background-color var(--duration-base) var(--ease-standard),
      color var(--duration-base) var(--ease-standard),
      transform var(--duration-base) var(--ease-standard);
  }

  .positions-link-chip:hover {
    border-color: var(--color-black);
    background: var(--color-black);
    color: var(--color-white);
    transform: translateY(calc(var(--space-1) * -1));
  }

  .positions-openings-cluster__header h4,
  .positions-staff-overview__copy h4,
  .position-card__title {
    margin: 0;
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
  }

  .positions-openings-cluster__header h4,
  .positions-staff-overview__copy h4 {
    font-size: var(--text-2xl);
  }

  .position-card__title {
    font-size: var(--text-xl);
  }

  .position-card__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .position-status-chip {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-tiny);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .position-status-chip--open {
    background: var(--color-green-100);
    color: var(--color-green-700);
  }

  .position-status-chip--closed {
    background: var(--color-gray-200);
    color: var(--color-gray-600);
  }

  .position-status-chip--archived {
    background: var(--color-blue-50);
    color: var(--color-monash-blue);
  }

  .position-card__meta {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .position-card__meta-item {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: var(--border-subtle);
  }

  .position-card__primary-action {
    justify-self: start;
  }

  .position-card--open {
    border-color: var(--color-blue-100);
  }

  .position-card--archived {
    border-color: var(--color-gray-200);
    background: var(--color-gray-50);
  }

  .positions-separator {
    height: 1px;
    background: var(--color-gray-200);
  }

  .positions-staff-overview {
    gap: var(--space-8);
    align-items: start;
  }

  .positions-inclusion-card {
    border: 1px solid var(--color-blue-100);
    background: var(--color-blue-50);
  }

  .positions-inclusion-card__quote {
    color: var(--color-blue-800);
    font-size: var(--text-lg);
    font-style: italic;
  }

  .positions-inclusion-card__label {
    color: var(--color-monash-blue);
  }

  @media (min-width: 48rem) {
    .positions-card-list--staff {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .position-card__meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .positions-group__grid,
    .positions-staff-overview {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-12);
    }

    .positions-group__heading--end {
      text-align: right;
    }

    .positions-card-list,
    .positions-card-list--staff {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
