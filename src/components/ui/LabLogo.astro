---
interface Props {
  href?: string;
  inverse?: boolean;
}

const { href = '/', inverse = false } = Astro.props;
---

<a
  href={href}
  class="lab-logo"
  data-inverse={inverse ? 'true' : 'false'}
  data-testid="lab-logo"
>
  <span class="lab-logo__mark" aria-hidden="true">VL</span>
  <span class="lab-logo__wordmark">
    <span class="lab-logo__title">VL4AI</span>
    <span class="lab-logo__subtitle">Laboratory</span>
  </span>
</a>
