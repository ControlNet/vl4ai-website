---
interface NavItem {
  key?: string;
  label: string;
  href: string;
  testId?: string;
}

interface Props {
  activeItem?: string;
  items?: readonly NavItem[];
  logoHref?: string;
}

const { activeItem, items = [], logoHref = '/' } = Astro.props;
const normalizePath = (value: string) => {
  if (value === '/' || value.endsWith('/') || value.endsWith('.html')) {
    return value;
  }

  return `${value}/`;
};
const currentPath = normalizePath(Astro.url.pathname);
const isItemActive = (item: NavItem) =>
  activeItem ? activeItem === item.key : normalizePath(item.href) === currentPath;
---

<nav
  class="glass-nav fixed top-0 left-0 z-50 flex w-full items-center justify-between border-b border-gray-100 px-6 py-4 md:px-12"
  id="site-nav"
  data-testid="site-nav"
>
  <div class="relative z-10 flex items-center gap-3">
    <a href={logoHref} class="group flex items-center gap-3" data-testid="site-nav-home">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-black transition-transform group-hover:scale-110">
        <span class="text-sm font-extrabold text-white">VL</span>
      </div>
      <span class="text-2xl font-black uppercase tracking-tighter">
        VL4AI <span class="font-light text-gray-500">Research</span>
      </span>
    </a>
  </div>

  <div
    id="site-nav-mobile-panel"
    class="glass-panel absolute top-full right-0 left-0 z-10 mx-4 mt-2 hidden max-h-[min(70vh,calc(100dvh-5.5rem))] flex-col gap-0 overflow-y-auto overscroll-contain rounded-2xl border border-white/60 p-2 pb-[max(0.5rem,env(safe-area-inset-bottom))] text-[11px] font-black uppercase tracking-widest shadow-2xl shadow-black/10 lg:static lg:mx-0 lg:mt-0 lg:max-h-none lg:max-w-none lg:overflow-visible lg:p-0 lg:pb-0 lg:flex lg:w-auto lg:flex-row lg:items-center lg:gap-10 lg:border-0 lg:bg-transparent lg:shadow-none lg:[backdrop-filter:none] lg:[-webkit-backdrop-filter:none]"
    aria-label="Primary navigation"
    aria-hidden="true"
    data-mobile-menu-panel
  >
    {
      items.map((item) => (
        <a
          href={item.href}
          class:list={[
            'nav-link block rounded-xl px-4 py-3.5 text-sm transition max-lg:w-full max-lg:min-h-[2.75rem] max-lg:leading-snug max-lg:after:hidden lg:inline lg:w-fit lg:min-h-0 lg:px-0 lg:py-0 lg:text-[11px]',
            isItemActive(item) ? 'is-active text-black max-lg:bg-gray-50' : 'text-gray-600 hover:text-[#003087] max-lg:active:bg-gray-100',
          ]}
          aria-current={isItemActive(item) ? 'page' : undefined}
          data-mobile-menu-link
          data-testid={item.testId ?? `site-nav-link-${item.key ?? item.label.toLowerCase().replace(/\s+/g, '-')}`}
        >
          {item.label}
        </a>
      ))
    }
  </div>

  <button
    class="relative z-10 inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full text-gray-900 transition hover:bg-blue-50 hover:text-[#003087] lg:hidden"
    type="button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="site-nav-mobile-panel"
    data-mobile-menu-button
    data-testid="site-nav-menu-button"
  >
    <svg
      class="h-5 w-5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      aria-hidden="true"
      data-mobile-menu-icon-open
    >
      <path d="M4 7h16"></path>
      <path d="M7 12h13"></path>
      <path d="M10 17h10"></path>
    </svg>
    <svg
      class="absolute h-5 w-5 hidden"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      aria-hidden="true"
      data-mobile-menu-icon-close
    >
      <path d="M6 6l12 12"></path>
      <path d="M18 6L6 18"></path>
    </svg>
  </button>

</nav>

<script is:inline>
  (() => {
    const mobileNav = document.getElementById('site-nav');

    if (!(mobileNav instanceof HTMLElement)) {
      return;
    }

    const mobileMenuButton = mobileNav.querySelector('[data-mobile-menu-button]');
    const mobileMenuPanel = mobileNav.querySelector('[data-mobile-menu-panel]');
    const mobileMenuLinks = mobileNav.querySelectorAll('[data-mobile-menu-link]');
    const menuIconOpen = mobileMenuButton?.querySelector('[data-mobile-menu-icon-open]');
    const menuIconClose = mobileMenuButton?.querySelector('[data-mobile-menu-icon-close]');

    if (!(mobileMenuButton instanceof HTMLButtonElement) || !(mobileMenuPanel instanceof HTMLElement)) {
      return;
    }

    const desktopMediaQuery = window.matchMedia('(min-width: 64rem)');

    const setMenuState = (isOpen) => {
      const menuIsOpen = isOpen && !desktopMediaQuery.matches;

      mobileNav.dataset.mobileMenuOpen = menuIsOpen ? 'true' : 'false';
      mobileMenuButton.setAttribute('aria-expanded', String(menuIsOpen));
      mobileMenuButton.setAttribute('aria-label', menuIsOpen ? 'Close navigation menu' : 'Open navigation menu');
      mobileMenuPanel.setAttribute('aria-hidden', desktopMediaQuery.matches ? 'false' : String(!menuIsOpen));
      mobileMenuPanel.classList.toggle('hidden', !menuIsOpen && !desktopMediaQuery.matches);

      if (menuIconOpen instanceof SVGElement && menuIconClose instanceof SVGElement) {
        menuIconOpen.classList.toggle('hidden', Boolean(menuIsOpen));
        menuIconClose.classList.toggle('hidden', !menuIsOpen);
      }
    };

    const closeMenu = () => {
      setMenuState(false);
    };

    setMenuState(false);

    mobileMenuButton.addEventListener('click', () => {
      setMenuState(mobileNav.dataset.mobileMenuOpen !== 'true');
    });

    mobileMenuLinks.forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    document.addEventListener('click', (event) => {
      if (desktopMediaQuery.matches || mobileNav.dataset.mobileMenuOpen !== 'true') {
        return;
      }

      if (event.target instanceof Node && !mobileNav.contains(event.target)) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenu();
      }
    });

    const handleBreakpointChange = () => {
      closeMenu();
    };

    if (typeof desktopMediaQuery.addEventListener === 'function') {
      desktopMediaQuery.addEventListener('change', handleBreakpointChange);
    } else {
      desktopMediaQuery.addListener(handleBreakpointChange);
    }
  })();
</script>
