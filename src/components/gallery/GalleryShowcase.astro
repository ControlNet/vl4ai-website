---
import { toContentAssetUrl } from '../../lib/content-assets';
import { resolveRouteDestination } from '../../lib/route-destination';
import GalleryMediaFrame from './GalleryMediaFrame.astro';
import { getGallerySpanClasses, type GalleryCollectionItem } from './gallery-data';

interface GalleryCallToAction {
  label: string;
  href: string;
  external: boolean;
}

interface PreparedGalleryItem {
  id: string;
  title: string;
  description: string;
  alt: string;
  mediaType: GalleryCollectionItem['mediaType'];
  mediaUrls: string[];
  posterUrl?: string;
  spanClass: string;
  cta?: GalleryCallToAction;
}

interface Props {
  items: GalleryCollectionItem[];
}

const { items: sourceItems } = Astro.props as Props;
const toMediaUrl = (value: string) => (/^https?:\/\//u.test(value) ? value : toContentAssetUrl(value));

const items: PreparedGalleryItem[] = sourceItems.map((item) => ({
  id: item.id,
  title: item.title,
  description: item.description,
  alt: item.alt,
  mediaType: item.mediaType,
  mediaUrls: item.media.map(toMediaUrl),
  posterUrl: item.poster ? toMediaUrl(item.poster) : undefined,
  spanClass: getGallerySpanClasses(item.aspectRatio),
  cta:
    item.ctaLabel && item.ctaUrl
      ? {
          label: item.ctaLabel,
          ...resolveRouteDestination(item.ctaUrl),
        }
      : undefined,
}));
---

<section class="mx-auto max-w-7xl px-6 pt-12 pb-24" data-testid="gallery-showcase">
  <div
    class="grid grid-cols-1 auto-rows-[11rem] grid-flow-dense gap-3 sm:grid-cols-2 sm:auto-rows-[13rem] lg:grid-cols-3 lg:auto-rows-[12rem]"
    data-testid="gallery-grid"
  >
    {
      items.map((item) => (
        <button
          type="button"
          class:list={['gallery-card group relative isolate overflow-hidden rounded-[1.75rem] border border-gray-100 bg-gray-100 text-left shadow-sm', item.spanClass]}
          data-gallery-open={item.id}
          data-gallery-media-type={item.mediaType}
          data-testid="gallery-card"
          aria-label={`Open gallery details for ${item.title}`}
          aria-haspopup="dialog"
          aria-controls="gallery-lightbox"
        >
          <div class="absolute inset-0 bg-gray-950">
            <GalleryMediaFrame
              title={item.title}
              alt={item.alt}
              mediaType={item.mediaType}
              mediaUrls={item.mediaUrls}
              posterUrl={item.posterUrl}
              mode="card"
            />
          </div>

          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 z-[1] h-[42%] bg-gradient-to-t from-black/75 via-black/35 to-transparent transition-all duration-500 ease-out group-hover:h-[70%] group-hover:from-black/90 group-hover:via-black/55 group-focus-visible:h-[70%] group-focus-visible:from-black/90 group-focus-visible:via-black/55"
            aria-hidden="true"
          >
          </div>

          <div class="relative z-[2] flex h-full flex-col justify-end p-5 sm:p-6 md:p-8">
            <div class="gallery-card__meta w-full translate-y-8 transform transition-transform duration-500 ease-out group-hover:translate-y-0 group-focus-visible:translate-y-0">
              <h3 class="mb-2 max-w-[22rem] text-2xl leading-tight font-black tracking-tight text-white md:text-3xl">
                {item.title}
              </h3>
              <div
                class="grid grid-rows-[0fr] transition-all duration-500 group-hover:grid-rows-[1fr] group-focus-visible:grid-rows-[1fr]"
              >
                <div class="min-h-0 overflow-hidden">
                  <div class="mt-3 flex w-full items-end justify-between gap-3">
                    <p class="max-w-[22rem] min-w-0 flex-1 line-clamp-2 text-sm leading-relaxed text-white/82">
                      {item.description}
                    </p>
                    <p
                      class="pointer-events-none shrink-0 max-w-[9.5rem] text-right text-xs leading-snug font-medium text-white/80"
                      aria-hidden="true"
                    >
                      Click to view details
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </button>
      ))
    }
  </div>

  <div class="hidden" aria-hidden="true">
    {
      items.map((item) => (
        <div data-gallery-template={item.id}>
          <div class="gallery-modal__panel flex w-full max-w-full flex-col overflow-hidden rounded-[2rem] border border-gray-100 bg-white shadow-2xl lg:flex-row lg:max-h-[85vh]">
            <div
              class="relative flex min-h-0 min-w-0 flex-1 flex-col items-center justify-center bg-gray-950"
              data-testid="gallery-modal-media"
            >
              <GalleryMediaFrame
                title={item.title}
                alt={item.alt}
                mediaType={item.mediaType}
                mediaUrls={item.mediaUrls}
                posterUrl={item.posterUrl}
                mode="modal"
              />
            </div>

            <div
              class="flex w-full shrink-0 flex-col gap-6 overflow-y-auto p-6 sm:p-8 lg:w-[24rem] lg:p-10 xl:w-[28rem]"
              data-testid="gallery-modal-details"
            >
              <div class="space-y-4">
                <h2 id="gallery-dialog-title" class="text-3xl leading-tight font-black tracking-tight text-gray-900 md:text-5xl">
                  {item.title}
                </h2>
                <p class="text-base leading-relaxed text-gray-500 md:text-lg">{item.description}</p>
              </div>

              {item.cta && (
                <div class="mt-auto pt-2">
                  <a
                    href={item.cta.href}
                    class="inline-flex items-center gap-2 rounded-full bg-[var(--color-monash-blue)] px-6 py-3 text-[0.6875rem] font-black uppercase tracking-[0.24em] text-white transition hover:bg-[var(--color-accent-blue)]"
                    target={item.cta.external ? '_blank' : undefined}
                    rel={item.cta.external ? 'noreferrer' : undefined}
                  >
                    {item.cta.label}
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M13 5h6v6h-2V8.414l-8.293 8.293-1.414-1.414L15.586 7H13z"></path>
                      <path d="M5 5h6v2H7v10h10v-4h2v6H5z"></path>
                    </svg>
                  </a>
                </div>
              )}
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <dialog id="gallery-lightbox" class="gallery-modal m-0 h-full max-h-none w-full max-w-none bg-transparent p-4 md:p-10" data-gallery-modal data-testid="gallery-modal">
    <div class="mx-auto flex min-h-full max-w-6xl items-center justify-center">
      <div class="pointer-events-auto flex w-full justify-center" data-gallery-modal-content></div>
    </div>
  </dialog>
</section>

<script is:inline>
  (() => {
    const updateGallerySequenceDots = (root, activeIndex) => {
      root.querySelectorAll('[data-gallery-sequence-dot]').forEach((dot, idx) => {
        const on = idx === activeIndex;
        dot.classList.toggle('w-5', on);
        dot.classList.toggle('w-1.5', !on);
        dot.classList.toggle('bg-[var(--color-monash-blue)]', on);
        dot.classList.toggle('bg-[var(--color-monash-blue)]/45', !on);
      });
    };

    const stopGalleryImageSequence = (root) => {
      const raw = root.dataset.gallerySequenceTimerId;
      if (raw) {
        window.clearInterval(Number.parseInt(raw, 10));
        delete root.dataset.gallerySequenceTimerId;
      }
    };

    const startGalleryImageSequence = (root) => {
      const slides = root.querySelectorAll('[data-gallery-sequence-slide]');
      if (slides.length < 2) {
        return;
      }

      stopGalleryImageSequence(root);

      const intervalMs = Number.parseInt(root.dataset.gallerySequenceInterval || '3000', 10);
      let i = 0;

      const id = window.setInterval(() => {
        const next = (i + 1) % slides.length;
        slides[i].classList.remove('opacity-100');
        slides[i].classList.add('opacity-0');
        slides[next].classList.remove('opacity-0');
        slides[next].classList.add('opacity-100');
        updateGallerySequenceDots(root, next);
        i = next;
      }, intervalMs);

      root.dataset.gallerySequenceTimerId = String(id);
    };

    const startGallerySequencesInDocument = (scope) => {
      scope.querySelectorAll('[data-gallery-image-sequence]').forEach((node) => {
        if (!(node instanceof HTMLElement)) {
          return;
        }
        if (node.closest('[data-gallery-template]')) {
          return;
        }
        startGalleryImageSequence(node);
      });
    };

    const stopGallerySequencesUnder = (root) => {
      root.querySelectorAll('[data-gallery-image-sequence]').forEach((node) => {
        if (node instanceof HTMLElement) {
          stopGalleryImageSequence(node);
        }
      });
    };

    const stopGalleryModalCarouselsUnder = (root) => {
      root.querySelectorAll('[data-gallery-modal-carousel]').forEach((node) => {
        if (!(node instanceof HTMLElement)) {
          return;
        }
        const raw = node.dataset.galleryModalCarouselTimerId;
        if (raw) {
          window.clearInterval(Number.parseInt(raw, 10));
          delete node.dataset.galleryModalCarouselTimerId;
        }
      });
    };

    const startGalleryModalCarousel = (root) => {
      if (!(root instanceof HTMLElement)) {
        return;
      }

      const track = root.querySelector('[data-gmc-track]');
      const slideEls = root.querySelectorAll('[data-gmc-slide]');
      const prevBtn = root.querySelector('[data-gmc-prev]');
      const nextBtn = root.querySelector('[data-gmc-next]');
      const dotBtns = root.querySelectorAll('[data-gmc-dot]');

      const total = slideEls.length;
      if (!(track instanceof HTMLElement) || total === 0 || !prevBtn || !nextBtn) {
        return;
      }

      const existingTimer = root.dataset.galleryModalCarouselTimerId;
      if (existingTimer) {
        window.clearInterval(Number.parseInt(existingTimer, 10));
        delete root.dataset.galleryModalCarouselTimerId;
      }

      const prefersReduced =
        typeof window.matchMedia === 'function' && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const intervalMs = 5000;

      let index = 0;

      const setIndex = (next) => {
        index = ((next % total) + total) % total;
        track.style.transform = `translateX(calc(-${index} * 100% / ${total}))`;

        slideEls.forEach((el, i) => {
          if (el instanceof HTMLElement) {
            el.setAttribute('aria-hidden', i === index ? 'false' : 'true');
          }
        });

        dotBtns.forEach((btn, i) => {
          if (!(btn instanceof HTMLButtonElement)) {
            return;
          }

          const active = i === index;
          btn.classList.toggle('w-6', active);
          btn.classList.toggle('w-2', !active);
          btn.classList.toggle('bg-white', active);
          btn.classList.toggle('bg-white/40', !active);
          btn.classList.toggle('hover:bg-white/70', !active);
          if (active) {
            btn.setAttribute('aria-current', 'true');
          } else {
            btn.removeAttribute('aria-current');
          }
        });
      };

      const goPrev = () => setIndex(index - 1);
      const goNext = () => setIndex(index + 1);

      const stopTimer = () => {
        const raw = root.dataset.galleryModalCarouselTimerId;
        if (raw) {
          window.clearInterval(Number.parseInt(raw, 10));
          delete root.dataset.galleryModalCarouselTimerId;
        }
      };

      const startTimer = () => {
        if (prefersReduced) {
          return;
        }

        stopTimer();
        const id = window.setInterval(() => {
          setIndex(index + 1);
        }, intervalMs);
        root.dataset.galleryModalCarouselTimerId = String(id);
      };

      const restartTimer = () => {
        stopTimer();
        startTimer();
      };

      prevBtn.addEventListener('click', () => {
        goPrev();
        restartTimer();
      });

      nextBtn.addEventListener('click', () => {
        goNext();
        restartTimer();
      });

      dotBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (!(btn instanceof HTMLButtonElement)) {
            return;
          }

          const raw = btn.getAttribute('data-gmc-index');
          const target = raw === null ? NaN : Number.parseInt(raw, 10);
          if (Number.isFinite(target)) {
            setIndex(target);
            restartTimer();
          }
        });
      });

      root.addEventListener('mouseenter', stopTimer);
      root.addEventListener('mouseleave', startTimer);

      setIndex(0);
      startTimer();
    };

    const startGalleryModalCarouselsIn = (scope) => {
      scope.querySelectorAll('[data-gallery-modal-carousel]').forEach((node) => {
        if (node instanceof HTMLElement) {
          startGalleryModalCarousel(node);
        }
      });
    };

    const runSequenceInit = () => startGallerySequencesInDocument(document);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', runSequenceInit);
    } else {
      runSequenceInit();
    }

    const dialog = document.querySelector('[data-gallery-modal]');
    const contentHost = dialog?.querySelector('[data-gallery-modal-content]');
    const openButtons = document.querySelectorAll('[data-gallery-open]');
    let lastTrigger = null;

    if (!(dialog instanceof HTMLDialogElement) || !(contentHost instanceof HTMLDivElement)) {
      return;
    }

    const setScrollLock = (isLocked) => {
      document.documentElement.classList.toggle('overflow-hidden', isLocked);
      document.body.classList.toggle('overflow-hidden', isLocked);
    };

    const closeModal = () => {
      if (!dialog.open) {
        return;
      }

      dialog.close();
    };

    openButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const itemId = button.getAttribute('data-gallery-open');
        const template = itemId ? document.querySelector(`[data-gallery-template="${itemId}"]`) : null;

        if (!(template instanceof HTMLDivElement)) {
          return;
        }

        const panel = template.firstElementChild?.cloneNode(true);
        if (!(panel instanceof HTMLElement)) {
          return;
        }

        stopGalleryModalCarouselsUnder(contentHost);
        stopGallerySequencesUnder(contentHost);
        contentHost.replaceChildren(panel);
        startGallerySequencesInDocument(panel);
        startGalleryModalCarouselsIn(panel);

        lastTrigger = button instanceof HTMLElement ? button : null;

        if (typeof dialog.showModal === 'function') {
          dialog.showModal();
        } else {
          dialog.setAttribute('open', '');
        }

        setScrollLock(true);

        window.requestAnimationFrame(() => {
          const title = contentHost.querySelector('#gallery-dialog-title');
          if (title instanceof HTMLElement) {
            title.setAttribute('tabindex', '-1');
            title.focus({ preventScroll: true });
          }
        });
      });
    });

    dialog.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }

      if (target.closest('.gallery-modal__panel')) {
        return;
      }

      closeModal();
    });

    dialog.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeModal();
    });

    dialog.addEventListener('close', () => {
      stopGalleryModalCarouselsUnder(contentHost);
      stopGallerySequencesUnder(contentHost);
      setScrollLock(false);
      contentHost.replaceChildren();

      if (lastTrigger instanceof HTMLElement) {
        lastTrigger.focus();
      }

      lastTrigger = null;
    });
  })();
</script>

<style>
  .gallery-card {
    transition:
      transform var(--duration-base) var(--ease-emphasized),
      box-shadow var(--duration-base) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard);
  }

  .gallery-card:hover,
  .gallery-card:focus-visible {
    transform: translateY(calc(var(--space-1) * -1));
    box-shadow: var(--shadow-2xl);
    border-color: rgb(255 255 255 / 0.24);
  }

  .gallery-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgb(255 255 255 / 0.18);
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-standard);
    pointer-events: none;
  }

  .gallery-card:hover::after,
  .gallery-card:focus-visible::after {
    opacity: 1;
  }

  .gallery-modal::backdrop {
    background: rgb(17 24 39 / 0.72);
    backdrop-filter: blur(var(--nav-blur));
    -webkit-backdrop-filter: blur(var(--nav-blur));
  }

  .gallery-modal[open] {
    animation: gallery-modal-fade-in var(--duration-base) var(--ease-standard);
  }

  .gallery-modal__panel {
    animation: gallery-modal-panel-enter var(--duration-base) var(--ease-emphasized);
  }

  @keyframes gallery-modal-fade-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes gallery-modal-panel-enter {
    from {
      opacity: 0;
      transform: scale(0.96) translateY(var(--space-4));
    }

    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  </style>
