---
import type { GalleryMediaType } from './gallery-data';

interface Props {
  title: string;
  alt: string;
  mediaType: GalleryMediaType;
  mediaUrls: string[];
  posterUrl?: string;
  mode?: 'card' | 'modal';
}

const { title, alt, mediaType, mediaUrls, posterUrl, mode = 'card' } = Astro.props;
const isCard = mode === 'card';
const sequenceIntervalMs = 3000;

const cardFill = 'absolute inset-0 h-full w-full';
const modalMediaClasses = 'block h-auto w-auto max-h-[40vh] md:max-h-[50vh] lg:max-h-[85vh] max-w-full object-contain';
---

{
  mediaType === 'video' ? (
    isCard ? (
      <video
        class={`${cardFill} object-cover`}
        src={mediaUrls[0]}
        poster={posterUrl}
        autoplay
        loop
        muted
        playsinline
        preload="none"
        aria-label={title}
      />
    ) : (
      <video
        class={modalMediaClasses}
        src={mediaUrls[0]}
        poster={posterUrl}
        autoplay
        loop
        muted
        playsinline
        controls
        preload="metadata"
        aria-label={title}
      />
    )
  ) : mediaType === 'images' ? (
    isCard ? (
      <div
        class="absolute inset-0 overflow-hidden bg-gray-950"
        data-gallery-image-sequence
        data-gallery-sequence-interval={String(sequenceIntervalMs)}
      >
        {mediaUrls.map((mediaUrl, index) => (
          <img
            src={mediaUrl}
            alt={`${alt} (${index + 1} of ${mediaUrls.length})`}
            data-gallery-sequence-slide
            class:list={[
              `${cardFill} object-cover transition-opacity duration-1000 ease-in-out`,
              index === 0 ? 'opacity-100' : 'opacity-0',
            ]}
            loading={mediaUrls.length > 1 ? 'eager' : 'lazy'}
            decoding="async"
          />
        ))}
      </div>
    ) : (
      <div
        class="relative grid place-items-center"
        data-gallery-image-sequence
        data-gallery-sequence-interval={String(sequenceIntervalMs)}
      >
        {mediaUrls.map((mediaUrl, index) => (
          <img
            src={mediaUrl}
            alt={`${alt} (${index + 1} of ${mediaUrls.length})`}
            data-gallery-sequence-slide
            class:list={[`col-start-1 row-start-1 transition-opacity duration-1000 ease-in-out ${modalMediaClasses}`, index === 0 ? 'opacity-100' : 'opacity-0']}
            loading={mediaUrls.length > 1 ? 'eager' : undefined}
            decoding="async"
          />
        ))}
        {mediaUrls.length > 1 && (
          <div
            class="pointer-events-none absolute right-4 bottom-4 z-[1] inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white/90 px-3 py-1.5 text-[0.6rem] font-black uppercase tracking-[0.28em] text-gray-500"
            aria-hidden="true"
          >
            <span class="inline-flex gap-1.5">
              {mediaUrls.map((_, index) => (
                <span
                  data-gallery-sequence-dot
                  class:list={[
                    'h-1.5 rounded-full transition-all duration-500',
                    index === 0 ? 'w-5 bg-[var(--color-monash-blue)]' : 'w-1.5 bg-[var(--color-monash-blue)]/45',
                  ]}
                ></span>
              ))}
            </span>
            <span>Series</span>
          </div>
        )}
      </div>
    )
  ) : isCard ? (
    <img
      src={mediaUrls[0]}
      alt={alt}
      class={`${cardFill} object-cover`}
      loading="lazy"
      decoding="async"
    />
  ) : (
    <img
      src={mediaUrls[0]}
      alt={alt}
      class={modalMediaClasses}
      decoding="async"
    />
  )
}
