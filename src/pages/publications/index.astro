---
import { getCollection, type CollectionEntry } from 'astro:content';

import { footerUtilityLink, navContactCta, publicNavItems } from '../../data/route-contract';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { routeSeo } from '../../lib/page-seo';

type PublicationEntry = CollectionEntry<'publications'>;

interface SiteRouteCopyData {
  kind: 'route-copy';
  localeKey: string;
  sortOrder: number;
  route: string;
  title: string;
  highlight?: string;
  lede: string;
  actions: Array<{
    label: string;
    style: 'primary' | 'secondary';
    url?: string;
  }>;
}

type SiteRouteCopyEntry = CollectionEntry<'site'> & { data: SiteRouteCopyData };

interface PublicationActionLink {
  kind: string;
  label: string;
  href: string;
  external: boolean;
}

interface PublicationRow {
  id: string;
  title: string;
  authorLine: string;
  venue: string;
  year: number;
  archiveGroup: string;
  badgeLabel: string;
  links: PublicationActionLink[];
}

interface PublicationYearGroup {
  label: string;
  leadYear: number;
  items: PublicationRow[];
}

const siteEntries = await getCollection('site');
const publicationEntries = await getCollection('publications');

const publicationsRouteCopy = siteEntries.find(
  (entry): entry is SiteRouteCopyEntry => entry.data.kind === 'route-copy' && entry.data.route === '/publications/',
);

if (!publicationsRouteCopy) {
  throw new Error('Expected a route-copy entry for /publications/ in the site collection.');
}

const sortPublicationEntries = (left: PublicationEntry, right: PublicationEntry) =>
  right.data.year - left.data.year || left.data.sequence - right.data.sequence || left.id.localeCompare(right.id);

const extractVenueBadgeLabel = (venue: string) => {
  const acronym = Array.from(venue.matchAll(/\(([A-Z0-9./& -]{2,})\)/gu))
    .map((match) => match[1]?.trim())
    .find((candidate): candidate is string => Boolean(candidate && /[A-Z]/u.test(candidate)));

  if (acronym) {
    return acronym.replace(/\s+/gu, ' ');
  }

  if (/^arxiv/iu.test(venue)) {
    return 'ARXIV';
  }

  return venue.split(',')[0]?.trim() ?? venue;
};

const isExternalLink = (value: string) => /^https?:\/\//iu.test(value) || value.startsWith('mailto:');

const publicationRows: PublicationRow[] = publicationEntries.slice().sort(sortPublicationEntries).map((entry) => ({
  id: entry.id,
  title: entry.data.title,
  authorLine: entry.data.authors.join(', '),
  venue: entry.data.venue,
  year: entry.data.year,
  archiveGroup: entry.data.archiveGroup,
  badgeLabel: extractVenueBadgeLabel(entry.data.venue),
  links: entry.data.links.map((link) => ({
    kind: link.kind,
    label: link.label,
    href: link.url,
    external: isExternalLink(link.url),
  })),
}));

const yearGroups: PublicationYearGroup[] = Array.from(
  publicationRows.reduce((groupMap, row) => {
    const existing = groupMap.get(row.archiveGroup);

    if (existing) {
      existing.items.push(row);
      return groupMap;
    }

    groupMap.set(row.archiveGroup, {
      label: row.archiveGroup,
      leadYear: row.year,
      items: [row],
    });

    return groupMap;
  }, new Map<string, PublicationYearGroup>()).values(),
);

const headerActions = publicationsRouteCopy.data.actions.filter(
  (action): action is SiteRouteCopyData['actions'][number] & { url: string } => Boolean(action.url),
);
---

<SiteLayout
  title={routeSeo.publicationsArchive.title}
  description={routeSeo.publicationsArchive.description}
  canonicalPath="/publications/"
  socialImage={routeSeo.publicationsArchive.socialImage}
  socialImageAlt={routeSeo.publicationsArchive.socialImageAlt}
  activeNav="publications"
  navItems={publicNavItems}
  navCta={navContactCta}
  footerNavItems={publicNavItems}
  footerUtilityLink={footerUtilityLink}
>
  <section class="bg-gray-50 px-6 pt-40 pb-20" data-testid="publications-archive-header">
    <div class="mx-auto flex max-w-7xl flex-col items-end justify-between gap-8 md:flex-row">
      <div class="max-w-3xl">
        <h1 class="mb-6 text-6xl font-[900] uppercase tracking-tighter md:text-8xl">{publicationsRouteCopy.data.title}</h1>
        <p class="text-xl font-light text-gray-500">{publicationsRouteCopy.data.lede}</p>
      </div>
      {headerActions.length > 0 && (
        <div class="flex gap-4">
          {headerActions.map((action) => (
            <a
              href={action.url}
              class="flex items-center gap-2 rounded-full bg-gray-100 px-6 py-3 text-[10px] font-black uppercase tracking-widest transition hover:bg-black hover:text-white"
              target={isExternalLink(action.url) ? '_blank' : undefined}
              rel={isExternalLink(action.url) ? 'noreferrer' : undefined}
              data-testid="publications-scholar-cta"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="m12 3-10 5 10 5 8.182-4.091V16H22V8z"></path>
                <path d="M6 12.764V16c0 2.761 2.686 5 6 5s6-2.239 6-5v-3.236L12 16z"></path>
              </svg>
              {action.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-24">
    {
      yearGroups.map((group, groupIndex) => (
        <div
          class:list={[groupIndex < yearGroups.length - 1 && 'mb-32', groupIndex > 0 && 'opacity-80 hover:opacity-100 transition-opacity']}
          data-testid="publication-year-group"
          data-publication-year-sort={String(group.leadYear)}
        >
          <h2 class="mb-12 flex items-center gap-4 text-4xl font-black tracking-tighter">
            {group.label}
            <div class="h-px flex-grow bg-gray-100"></div>
          </h2>
          <div class="space-y-6">
            {group.items.map((item) => (
              <article
                class="group flex flex-col justify-between gap-8 rounded-2xl border border-gray-100 p-8 transition hover:border-blue-200 md:flex-row"
                data-publication-slug={item.id}
                data-testid="publication-archive-item"
              >
                <div class="space-y-4">
                  <div class="flex gap-2">
                    <span class="rounded-sm bg-blue-700 px-3 py-1 text-[9px] font-black uppercase tracking-tighter text-white">
                      {item.badgeLabel}
                    </span>
                  </div>
                  <h4 class="text-2xl font-bold transition group-hover:text-blue-800">{item.title}</h4>
                  <p class="font-medium italic text-gray-500">{item.authorLine}</p>
                  <p class="text-sm font-light text-gray-400">{item.venue}</p>
                </div>
                <div class="flex justify-center gap-4 md:flex-col" data-testid="publication-row-actions">
                  {item.links.map((link) => (
                    <a
                      href={link.href}
                      class="flex h-12 w-12 items-center justify-center rounded-full bg-gray-50 text-gray-400 transition hover:bg-gray-100 hover:text-black"
                      target={link.external ? '_blank' : undefined}
                      rel={link.external ? 'noreferrer' : undefined}
                      aria-label={`${item.title} ${link.label}`}
                      data-publication-link-kind={link.kind}
                    >
                      {
                        link.kind === 'pdf' ? (
                          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M6 2.75A2.25 2.25 0 0 0 3.75 5v14A2.25 2.25 0 0 0 6 21.25h12A2.25 2.25 0 0 0 20.25 19V8.19a2.25 2.25 0 0 0-.66-1.59l-3.19-3.19a2.25 2.25 0 0 0-1.59-.66Zm8 .5v4.5h4.5Z"></path>
                          </svg>
                        ) : link.kind === 'website' ? (
                          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 2a10 10 0 1 0 10 10A10.011 10.011 0 0 0 12 2m6.93 9h-3.046a16.799 16.799 0 0 0-1.348-5.113A8.02 8.02 0 0 1 18.93 11M12 4.038c.962 1.102 1.912 3.377 2.337 6.962H9.663C10.088 7.415 11.038 5.14 12 4.038M9.464 5.887A16.799 16.799 0 0 0 8.116 11H5.07a8.02 8.02 0 0 1 4.394-5.113M4.264 13h3.852a16.799 16.799 0 0 0 1.348 5.113A8.02 8.02 0 0 1 4.264 13M12 19.962c-.962-1.102-1.912-3.377-2.337-6.962h4.674c-.425 3.585-1.375 5.86-2.337 6.962m2.536-1.849A16.799 16.799 0 0 0 15.884 13h3.852a8.02 8.02 0 0 1-5.2 5.113"></path>
                          </svg>
                        ) : (
                          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M13 5h6v6h-2V8.414l-8.293 8.293-1.414-1.414L15.586 7H13z"></path>
                            <path d="M5 5h6v2H7v10h10v-4h2v6H5z"></path>
                          </svg>
                        )
                      }
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      ))
    }

    <div class="rounded-[3rem] border-2 border-dashed border-gray-200 bg-gray-50 py-20 text-center">
      <p class="text-[10px] font-black uppercase tracking-[0.5em] text-gray-300">
        Complete archive loaded: {publicationRows.length} records
      </p>
    </div>
  </section>
</SiteLayout>
