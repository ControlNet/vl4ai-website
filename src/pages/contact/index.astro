---
import { getCollection, type CollectionEntry } from 'astro:content';

import { footerUtilityLink, navContactCta, publicNavItems } from '../../data/route-contract';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { routeSeo } from '../../lib/page-seo';

interface SiteRouteCopyData {
  kind: 'route-copy';
  localeKey: string;
  sortOrder: number;
  route: string;
  title: string;
  highlight?: string;
  lede: string;
}

interface SiteContactData {
  kind: 'contact';
  localeKey: string;
  sortOrder: number;
  phone: string;
  email: string;
  officeHours: string;
  addressLines: string[];
  mapUrl: string;
  mapEmbedUrl: string;
}

type SiteRouteCopyEntry = CollectionEntry<'site'> & { data: SiteRouteCopyData };
type SiteContactEntry = CollectionEntry<'site'> & { data: SiteContactData };

const siteEntries = await getCollection('site');

const contactRouteCopy = siteEntries.find(
  (entry): entry is SiteRouteCopyEntry => entry.data.kind === 'route-copy' && entry.data.route === '/contact/',
);
const contactEntry = siteEntries.find((entry): entry is SiteContactEntry => entry.data.kind === 'contact');

if (!contactRouteCopy) {
  throw new Error('Expected a route-copy entry for /contact/ in the site collection.');
}

if (!contactEntry) {
  throw new Error('Expected a contact entry in the site collection.');
}

const [locationLabel, ...addressBodyLines] = contactEntry.data.addressLines;
const addressLines = addressBodyLines.length > 0 ? addressBodyLines : contactEntry.data.addressLines;
---

<SiteLayout
  title={routeSeo.contact.title}
  description={routeSeo.contact.description}
  canonicalPath="/contact/"
  socialImage={routeSeo.contact.socialImage}
  socialImageAlt={routeSeo.contact.socialImageAlt}
  activeNav="contact"
  navItems={publicNavItems}
  navCta={navContactCta}
  footerNavItems={publicNavItems}
  footerUtilityLink={footerUtilityLink}
>
  <section class="bg-gray-50 px-6 pt-40 pb-20" data-testid="contact-page-header">
    <div class="mx-auto max-w-7xl">
      <h1 class="mb-6 text-6xl font-[900] uppercase tracking-tighter md:text-8xl">
        {contactRouteCopy.data.title} <span class="text-gray-300">{contactRouteCopy.data.highlight}</span>
      </h1>
      <p class="max-w-2xl text-xl font-light text-gray-500">{contactRouteCopy.data.lede}</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-24">
    <div class="grid gap-20 lg:grid-cols-2">
      <div class="space-y-12">
        <div data-testid="contact-location-block">
          <h2 class="mb-8 border-l-4 border-[#003087] pl-4 text-xs font-black uppercase tracking-[0.4em] text-[#003087]">
            Location
          </h2>
          <div class="space-y-4 text-lg leading-relaxed font-light text-gray-600">
            <p class="contact-page__location-label font-bold text-black">{locationLabel}</p>
            <p class="contact-page__location-name text-black">VL4AI Research Group</p>
            <address>
              {addressLines.map((line) => (
                <p>{line}</p>
              ))}
            </address>
          </div>
        </div>

        <div data-testid="contact-details-block">
          <h2 class="mb-8 border-l-4 border-[#003087] pl-4 text-xs font-black uppercase tracking-[0.4em] text-[#003087]">
            Contact Details
          </h2>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-50 text-[#003087]">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24 11.36 11.36 0 0 0 3.58.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.49a1 1 0 0 1 1 1 11.36 11.36 0 0 0 .57 3.58 1 1 0 0 1-.24 1z"></path>
                </svg>
              </div>
              <a href={`tel:${contactEntry.data.phone.replace(/[^\d+]/gu, '')}`} class="text-lg font-light text-gray-600">
                {contactEntry.data.phone}
              </a>
            </div>
            <div class="flex items-center gap-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-50 text-[#003087]">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M3 6.75A1.75 1.75 0 0 1 4.75 5h14.5A1.75 1.75 0 0 1 21 6.75v10.5A1.75 1.75 0 0 1 19.25 19H4.75A1.75 1.75 0 0 1 3 17.25zm1.5.132v.176l7.5 5.204 7.5-5.204v-.176a.25.25 0 0 0-.25-.25H4.75a.25.25 0 0 0-.25.25m15 1.994-7.072 4.911a.75.75 0 0 1-.856 0L4.5 8.876v8.374c0 .138.112.25.25.25h14.5a.25.25 0 0 0 .25-.25z"></path>
                </svg>
              </div>
              <a href={`mailto:${contactEntry.data.email}`} class="text-lg font-light text-gray-600">
                {contactEntry.data.email}
              </a>
            </div>
          </div>
        </div>

        <div data-testid="contact-hours-block">
          <h2 class="mb-8 border-l-4 border-[#003087] pl-4 text-xs font-black uppercase tracking-[0.4em] text-[#003087]">
            Office Hours
          </h2>
          <p class="contact-page__hours-text text-lg font-light text-gray-600">{contactEntry.data.officeHours}</p>
          <p class="contact-page__hours-location mt-2 text-sm font-light text-gray-400">{contactEntry.data.addressLines.at(-2)} {contactEntry.data.addressLines.at(-1)}</p>
        </div>
      </div>

      <div class="min-h-[400px] overflow-hidden rounded-3xl border border-gray-100 shadow-2xl" data-testid="contact-map-block">
        <iframe
          src={contactEntry.data.mapEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          title="VL4AI map"
          referrerpolicy="no-referrer-when-downgrade"
          data-testid="contact-map-embed"
        ></iframe>
        <div class="flex items-center justify-between border-t border-gray-100 bg-white px-6 py-4">
          <p class="text-sm font-light text-gray-500">Campus Map</p>
          <a href={contactEntry.data.mapUrl} target="_blank" rel="noreferrer" class="text-sm font-bold text-gray-900">
            Open in Google Maps
          </a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
