---
import { getCollection, type CollectionEntry } from 'astro:content';

import SiteLayout from '../layouts/SiteLayout.astro';
import { toContentAssetUrl } from '../lib/content-assets';
import { routeSeo } from '../lib/page-seo';
import { resolveRouteDestination } from '../lib/route-destination';

type PublicationEntry = CollectionEntry<'publications'>;
type NewsEntry = CollectionEntry<'news'>;

interface SiteHomeCopyData {
  kind: 'home-copy';
  localeKey: string;
  sortOrder: number;
  title: string;
  lede: string;
}

interface SiteRouteCopyData {
  kind: 'route-copy';
  localeKey: string;
  sortOrder: number;
  route: string;
  eyebrow?: string;
  title: string;
  highlight?: string;
  lede: string;
  actions: Array<{
    label: string;
    style: 'primary' | 'secondary';
    url?: string;
  }>;
}

type SiteHomeEntry = CollectionEntry<'site'> & { data: SiteHomeCopyData };
type SiteRouteCopyEntry = CollectionEntry<'site'> & { data: SiteRouteCopyData };

interface FeaturedPublicationItemData {
  id: string;
  title: string;
  venueLabel: string;
  pdfHref?: string;
  pdfExternal?: boolean;
}

interface NewsPreviewItemData {
  slug: string;
  title: string;
  summary: string;
  dateLabel: string;
  imageUrl: string;
  imageAlt: string;
  href: string;
  external: boolean;
}

interface AboutCarouselSlide {
  imageSrc: string;
  imageAlt: string;
  title: string;
}

const peopleEntries = await getCollection('people');
const newsEntries = await getCollection('news');
const publicationEntries = await getCollection('publications');
const siteEntries = await getCollection('site');

const homeCopyEntry = siteEntries.find((entry): entry is SiteHomeEntry => entry.data.kind === 'home-copy');
const homeRouteCopy = siteEntries.find(
  (entry): entry is SiteRouteCopyEntry => entry.data.kind === 'route-copy' && entry.data.route === '/',
);
const directorEntry = peopleEntries.find(
  (entry) => entry.data.recordType === 'member' && entry.data.group === 'director',
);

if (!homeCopyEntry) {
  throw new Error('Expected a home-copy entry in the site collection.');
}

if (!homeRouteCopy) {
  throw new Error('Expected a route-copy entry for / in the site collection.');
}

if (!directorEntry) {
  throw new Error('Expected one current director entry in the people collection.');
}

const stripMarkdownToPlainText = (value: string) =>
  value
    .replace(/!\[[^\]]*\]\([^)]+\)/gu, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/gu, '$1')
    .replace(/^#{1,6}\s+/gmu, '')
    .replace(/^>\s?/gmu, '')
    .replace(/[*_`]/gu, '')
    .replace(/\s+/gu, ' ')
    .trim();

const getNonListParagraphs = (body: string) =>
  body
    .split(/\n\s*\n/gu)
    .map((block) => block.trim())
    .filter((block) => block.length > 0)
    .filter((block) => {
      const lines = block
        .split('\n')
        .map((line) => line.trim())
        .filter(Boolean);

      return lines.length > 0 && !lines.every((line) => /^(?:[-*+]|\d+\.)\s/u.test(line));
    })
    .map(stripMarkdownToPlainText)
    .filter((paragraph) => paragraph.length > 0);

const getMarkdownListItems = (body: string) =>
  body
    .split('\n')
    .map((line) => line.trim())
    .filter((line) => /^[-*+]\s+/u.test(line))
    .map((line) => stripMarkdownToPlainText(line.replace(/^[-*+]\s+/u, '')))
    .filter((item) => item.length > 0);

const normalizeText = (value: string) => value.replace(/\s+/gu, ' ').trim();

const extractVenueBadgeLabel = (venue: string) => {
  const acronym = Array.from(venue.matchAll(/\(([A-Z0-9./& -]{2,})\)/gu))
    .map((match) => match[1]?.trim())
    .find((candidate): candidate is string => Boolean(candidate && /[A-Z]/u.test(candidate)));

  if (acronym) {
    return acronym.replace(/\s+/gu, ' ');
  }

  if (/^arxiv/iu.test(venue)) {
    return 'ARXIV';
  }

  return venue.split(',')[0]?.trim() ?? venue;
};

const sortFeaturedPublicationEntries = (left: PublicationEntry, right: PublicationEntry) =>
  (left.data.homeRank ?? Number.MAX_SAFE_INTEGER) - (right.data.homeRank ?? Number.MAX_SAFE_INTEGER) ||
  right.data.year - left.data.year ||
  left.data.sequence - right.data.sequence ||
  left.id.localeCompare(right.id);

const sortFeaturedNewsEntries = (left: NewsEntry, right: NewsEntry) =>
  right.data.date.localeCompare(left.data.date) ||
  left.data.sequence - right.data.sequence ||
  left.id.localeCompare(right.id);

const formatNewsDateLabel = (date: string) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(`${date}T00:00:00Z`));

const homeCopyParagraphs = getNonListParagraphs(homeCopyEntry.body ?? '');
const homeCopyListItems = getMarkdownListItems(homeCopyEntry.body ?? '');
const researchHeroAction = homeRouteCopy.data.actions.find((action) => action.url === '/research/');
const publicationsHeroAction = homeRouteCopy.data.actions.find((action) => action.url === '/publications/');
const aboutParagraphs = homeCopyParagraphs.slice(0, 2);
const aboutEmphasis = homeCopyParagraphs[2] ?? homeCopyParagraphs.at(-1) ?? homeCopyEntry.data.lede;
const directorImageUrl = directorEntry.data.image ? toContentAssetUrl(directorEntry.data.image) : undefined;
const directorRole = directorEntry.data.details[0] ?? 'Director';
const directorDisplayName = directorEntry.data.name.replace(/^(?:A\/)?Prof\.\s+/u, '').trim();
const totalPublicationCount = publicationEntries.length;
const publicationCountLabel =
  totalPublicationCount >= 10 ? `${Math.floor(totalPublicationCount / 10) * 10}+` : String(totalPublicationCount);

/** Same order and copy as the legacy site homepage carousel (`vl4ai-website-old/index.html`). `JRDB.png` → `JRDB-teaser.png` (asset name in this repo). */
const aboutCarouselSlides: readonly AboutCarouselSlide[] = [
  {
    imageSrc: '/images/slider/BasicVision.png',
    imageAlt: 'Basic vision: object detection and segmentation',
    title: 'Basic Vision Problems: Object Detection & Segmentation',
  },
  {
    imageSrc: '/images/slider/MOT2.png',
    imageAlt: 'Multi-object tracking',
    title: 'Multi-Object Tracking',
  },
  {
    imageSrc: '/images/slider/3Drec.png',
    imageAlt: '3D reconstruction in dynamic scenes',
    title: '3D Reconstruction of Human and Objects in Dynamic Scenes',
  },
  {
    imageSrc: '/images/slider/JRMOT.png',
    imageAlt: 'Multi-task 3D visual perception for mobile robots',
    title: 'Multi-task 3D Visual Perception System for a Mobile Robot in Human Environments',
  },
  {
    imageSrc: '/images/slider/JRDB-teaser.png',
    imageAlt: 'JRDB dataset and benchmark',
    title: 'JRDB: JackRabbot Dataset and Benchmark',
  },
  {
    imageSrc: '/images/slider/TRiPOD-SoPhie.png',
    imageAlt: 'Human trajectory and body motion forecasting',
    title: 'Human Trajectory/Body Motion Forecasting',
  },
  {
    imageSrc: '/images/slider/JRDB-ACT.png',
    imageAlt: 'Human action and activity detection',
    title: 'Human Spatio-temporal Action, Social Group and Activity Detection',
  },
  {
    imageSrc: '/images/slider/VN.png',
    imageAlt: 'Active visual navigation',
    title: 'Active Visual Navigation in an Unexplored Environment',
  },
  {
    imageSrc: '/images/slider/UAV.jpg',
    imageAlt: 'UAV planning for tracking mobile objects',
    title: 'Single or Multi-UAV Planning for Discovering and Tracking Mobile Objects',
  },
];

const aboutCarouselSlideCount = aboutCarouselSlides.length;
const aboutCarouselTrackItemCount = aboutCarouselSlideCount + 1;
const aboutCarouselTrackItemWidthPct = 100 / aboutCarouselTrackItemCount;

if (!researchHeroAction || !publicationsHeroAction) {
  throw new Error('Expected canonical /research/ and /publications/ hero actions in the / route-copy entry.');
}

/** Homepage Seminal Works: all publications that set `homeRank` (currently capped by content). */
const featuredPublicationItems: FeaturedPublicationItemData[] = publicationEntries
  .filter((entry) => entry.data.homeRank !== undefined)
  .sort(sortFeaturedPublicationEntries)
  .slice(0, 12)
  .map((entry) => {
    const pdfLink = entry.data.links.find((link) => link.kind === 'pdf');
    const pdfDest = pdfLink ? resolveRouteDestination(pdfLink.url) : undefined;

    return {
      id: entry.id,
      title: normalizeText(entry.data.title),
      venueLabel: `${extractVenueBadgeLabel(entry.data.venue)} ${entry.data.year}`,
      ...(pdfDest ? { pdfHref: pdfDest.href, pdfExternal: pdfDest.external } : {}),
    };
  });

const featuredNewsItems: NewsPreviewItemData[] = newsEntries
  .slice()
  .sort(sortFeaturedNewsEntries)
  .slice(0, 3)
  .map((entry) => ({
    slug: entry.id,
    title: normalizeText(entry.data.title).replace(/\.$/u, ''),
    summary: normalizeText(entry.data.summary).replace(/\.$/u, ''),
    dateLabel: formatNewsDateLabel(entry.data.date),
    imageUrl: toContentAssetUrl(entry.data.image),
    imageAlt: `${normalizeText(entry.data.title)} artwork`,
    ...resolveRouteDestination(entry.data.link),
  }));
---

<SiteLayout
  title={routeSeo.home.title}
  description={routeSeo.home.description}
  canonicalPath="/"
  socialImage={routeSeo.home.socialImage}
  socialImageAlt={routeSeo.home.socialImageAlt}
>
  <section
    class="hero-gradient relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 pt-20 text-center"
    data-testid="home-hero-section"
  >
    <div class="pointer-events-none absolute inset-0 opacity-[0.02]">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
            <path d="M 80 0 L 0 0 0 80" fill="none" stroke="black" stroke-width="1"></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"></rect>
      </svg>
    </div>

    <div class="z-10 max-w-6xl">
      {homeRouteCopy.data.eyebrow && (
        <div
          class="mb-8 inline-block rounded-full bg-blue-50 px-4 py-1.5 text-[10px] font-black uppercase tracking-[0.3em] text-[#003087]"
          data-testid="home-hero-eyebrow"
        >
          {homeRouteCopy.data.eyebrow}
        </div>
      )}
      <h1 class="mb-8 text-5xl leading-[0.9] font-[900] uppercase tracking-tighter md:text-8xl">
        {homeRouteCopy.data.title} <br />
        {homeRouteCopy.data.highlight && (
          <span class="bg-gradient-to-r from-[#003087] to-[#006DAE] bg-clip-text text-transparent">
            {homeRouteCopy.data.highlight}
          </span>
        )}
      </h1>
      <p class="home-hero__description mx-auto mb-12 max-w-3xl text-lg leading-relaxed font-light text-gray-500 md:text-2xl">
        {homeRouteCopy.data.lede}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={researchHeroAction.url}
          class="rounded-full bg-black px-10 py-5 text-[11px] font-bold uppercase tracking-widest text-white shadow-xl shadow-black/10 transition duration-300 hover:bg-[#003087]"
          data-testid="home-hero-research-cta"
        >
          {researchHeroAction.label}
        </a>
        <a
          href={publicationsHeroAction.url}
          class="rounded-full border border-gray-200 bg-white px-10 py-5 text-[11px] font-bold uppercase tracking-widest text-gray-900 transition duration-300 hover:border-[#003087] hover:bg-blue-50 hover:text-[#003087]"
          data-testid="home-hero-publications-cta"
        >
          {publicationsHeroAction.label}
        </a>
      </div>
    </div>

    <div class="absolute bottom-12 text-gray-300">
      <svg class="h-5 w-5 animate-bounce" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 16.5a1 1 0 0 1-.707-.293l-5-5 1.414-1.414L12 14.086l4.293-4.293 1.414 1.414-5 5A1 1 0 0 1 12 16.5Z"></path>
      </svg>
    </div>
  </section>

  <section id="about" class="px-6 py-32">
    <div class="mx-auto grid max-w-7xl items-start gap-24 lg:grid-cols-2">
      <div class="space-y-8">
        <div>
          <h2 class="mb-4 text-xs font-black uppercase tracking-[0.4em] text-[#003087]">About VL4AI Research</h2>
          <h3 class="mb-8 text-4xl leading-tight font-black tracking-tight md:text-5xl">
            Perceiving, Predicting, <br />&amp; Interacting.
          </h3>
          <div class="space-y-6 text-lg leading-relaxed font-light text-gray-600">
            {aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
            <ul class="space-y-4 pt-2">
              {
                homeCopyListItems.map((item) => (
                  <li class="flex items-start gap-4">
                    <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-blue-50">
                      <svg class="h-2.5 w-2.5 text-[#003087]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="m9.55 18.2-5.2-5.2 1.4-1.4 3.8 3.8 8.7-8.7 1.4 1.4z"></path>
                      </svg>
                    </div>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
            <p class="pt-4 font-medium text-gray-900">{aboutEmphasis}</p>
          </div>
        </div>
      </div>

      <div class="relative">
        <div
          class="relative aspect-[4/3] select-none overflow-hidden rounded-3xl bg-gray-100 shadow-2xl"
          data-testid="home-about-carousel"
          role="region"
          aria-roledescription="carousel"
          aria-label="Research highlights"
        >
          <div class="absolute inset-0 overflow-hidden">
            <div
              class="flex h-full transition-transform duration-700 ease-out motion-reduce:transition-none"
              style={{
                width: `${aboutCarouselTrackItemCount * 100}%`,
                transform: 'translateX(0)',
              }}
              data-carousel-track
            >
              {
                aboutCarouselSlides.map((slide, index) => (
                  <div
                    class="relative h-full min-h-0 shrink-0"
                    style={{ width: `${aboutCarouselTrackItemWidthPct}%` }}
                    data-carousel-slide
                    data-slide-title={slide.title}
                    aria-hidden={index === 0 ? 'false' : 'true'}
                  >
                    <img
                      src={slide.imageSrc}
                      alt={slide.imageAlt}
                      class="h-full w-full object-cover object-center opacity-90"
                      loading={index === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                      draggable="false"
                    />
                  </div>
                ))
              }
              <div
                class="relative h-full min-h-0 shrink-0"
                style={{ width: `${aboutCarouselTrackItemWidthPct}%` }}
                aria-hidden="true"
                data-carousel-clone
              >
                <img
                  src={aboutCarouselSlides[0]?.imageSrc}
                  alt=""
                  class="h-full w-full object-cover object-center opacity-90"
                  loading="lazy"
                  decoding="async"
                  draggable="false"
                />
              </div>
            </div>
          </div>

          <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-black/45 to-transparent"></div>

          <div class="pointer-events-none absolute top-10 left-10 max-w-xl pr-8 text-white">
            <p class="mb-2 text-[10px] font-black uppercase tracking-[0.3em] opacity-80">Research highlight</p>
            <h4 class="text-2xl font-bold" data-carousel-heading aria-live="polite">
              {aboutCarouselSlides[0].title}
            </h4>
          </div>

          <div
            class="pointer-events-none absolute inset-y-0 left-0 right-0 flex items-center justify-between px-2 md:px-3"
          >
            <button
              type="button"
              class="pointer-events-auto inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-black/35 text-white shadow-lg backdrop-blur-sm transition hover:bg-black/55"
              data-carousel-prev
              aria-label="Previous slide"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M15 18l-6-6 6-6"></path>
              </svg>
            </button>
            <button
              type="button"
              class="pointer-events-auto inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-black/35 text-white shadow-lg backdrop-blur-sm transition hover:bg-black/55"
              data-carousel-next
              aria-label="Next slide"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M9 18l6-6-6-6"></path>
              </svg>
            </button>
          </div>

          <div
            class="pointer-events-none absolute bottom-4 left-0 right-0 flex flex-wrap items-center justify-center gap-2 px-4"
            data-carousel-dots
          >
            {
              aboutCarouselSlides.map((_, index) => (
                <button
                  type="button"
                  class:list={[
                    'pointer-events-auto h-2 rounded-full transition-[width,background-color] duration-300',
                    index === 0 ? 'w-6 bg-white' : 'w-2 bg-white/40 hover:bg-white/70',
                  ]}
                  data-carousel-dot
                  data-carousel-index={index}
                  aria-label={`Go to slide ${index + 1}`}
                  aria-current={index === 0 ? 'true' : undefined}
                />
              ))
            }
          </div>
        </div>

        <div class="absolute -bottom-10 -left-10 hidden rounded-2xl border border-gray-100/80 bg-white/80 p-8 shadow-xl backdrop-blur-md md:block">
          <div class="mb-2 flex items-center gap-4">
            {directorImageUrl && (
              <img src={directorImageUrl} alt={directorEntry.data.name} class="h-10 w-10 rounded-full object-cover" />
            )}
            <div>
              <p class="text-[10px] leading-none font-black uppercase tracking-widest text-gray-400">Director</p>
              <p class="text-sm font-bold">{directorDisplayName}</p>
            </div>
          </div>
          <p class="text-4xl font-black text-[#003087]">{publicationCountLabel}</p>
          <p class="mt-1 text-[10px] font-black uppercase tracking-widest text-gray-400">Top-tier Papers</p>
          <p class="mt-3 max-w-[12rem] text-xs leading-relaxed font-medium text-gray-500">{directorRole}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 px-6 py-24">
    <div class="mx-auto mb-10 max-w-7xl text-center">
      <h2 class="mb-2 text-xs font-black uppercase tracking-[0.4em] text-[#003087]">Impact</h2>
      <h3 class="text-3xl font-black tracking-tight md:text-4xl">Seminal Works</h3>
    </div>

    <div class="mx-auto max-w-5xl space-y-2.5">
      {
        featuredPublicationItems.map((item) => (
          <article
            class="group flex flex-row items-center gap-3 rounded-2xl border border-gray-100 bg-white px-4 py-3.5 shadow-md transition-colors duration-300 hover:border-blue-200 sm:gap-4 sm:px-5 sm:py-4"
            data-publication-slug={item.id}
            data-testid="featured-publication"
          >
            <div class="min-w-0 flex-1">
              <p class="text-[9px] font-black uppercase tracking-widest text-blue-700">{item.venueLabel}</p>
              <h4 class="mt-1 text-base font-bold leading-snug text-gray-900 transition-colors group-hover:text-blue-900">{item.title}</h4>
            </div>
            {
              item.pdfHref && (
                <a
                  href={item.pdfHref}
                  class="inline-flex shrink-0 items-center justify-center gap-1.5 rounded-full border border-blue-100 bg-blue-50/50 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-blue-700 transition-all hover:border-[#003087] hover:bg-[#003087] hover:text-white hover:shadow-md active:scale-95"
                  target={item.pdfExternal ? '_blank' : undefined}
                  rel={item.pdfExternal ? 'noreferrer' : undefined}
                  data-testid="featured-publication-pdf"
                >
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M6 2.75A2.25 2.25 0 0 0 3.75 5v14A2.25 2.25 0 0 0 6 21.25h12A2.25 2.25 0 0 0 20.25 19V8.19a2.25 2.25 0 0 0-.66-1.59l-3.19-3.19a2.25 2.25 0 0 0-1.59-.66Zm8 .5v4.5h4.5Z" />
                  </svg>
                  PDF
                </a>
              )
            }
          </article>
        ))
      }
    </div>

    <div class="mt-8 text-center">
      <a
        href="/publications/"
        class="inline-flex items-center justify-center gap-2 text-xs font-black uppercase tracking-widest text-gray-400 transition hover:text-[#003087]"
        data-testid="home-publications-archive-cta"
      >
        View all publications
        <svg class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12.95 4.55 11.54 5.96l4.58 4.59H4v2h12.12l-4.58 4.59 1.41 1.41 7-7z"></path>
        </svg>
      </a>
    </div>
  </section>

  <section id="news" class="px-6 py-32">
    <div class="mx-auto max-w-7xl">
      <div class="mb-20 flex flex-col items-start justify-between gap-8 md:flex-row md:items-end">
        <div>
          <h2 class="mb-4 text-xs font-black uppercase tracking-[0.4em] text-[#003087]">Updates</h2>
          <h3 class="text-5xl font-[900] uppercase tracking-tighter">
            Latest <span class="text-gray-300">News</span>
          </h3>
        </div>
        <a
          href="/news/"
          class="rounded-full border border-gray-100 px-8 py-4 text-xs font-black uppercase tracking-widest transition hover:border-[#003087] hover:text-[#003087]"
          data-testid="home-news-archive-cta"
        >
          More News
        </a>
      </div>

      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
        {
          featuredNewsItems.map((item) => (
            <article class="group cursor-pointer" data-news-slug={item.slug} data-testid="news-preview-item">
              <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
                <div class="relative mb-6 aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
                  <img
                    src={item.imageUrl}
                    alt={item.imageAlt}
                    class="h-full w-full object-cover grayscale transition duration-700 group-hover:scale-110 group-hover:grayscale-0"
                    loading="lazy"
                  />
                  <div class="absolute top-6 left-6 rounded-full border border-white/60 bg-white/40 px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest text-gray-900 shadow-sm backdrop-blur-md">
                    {item.dateLabel}
                  </div>
                </div>
                <h4 class="text-xl leading-tight font-bold transition group-hover:text-blue-800">{item.title}</h4>
                <p class="mt-3 text-sm font-light text-gray-500">{item.summary}</p>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-testid="home-about-carousel"]');
      if (!(root instanceof HTMLElement)) {
        return;
      }

      const track = root.querySelector('[data-carousel-track]');
      const slideEls = root.querySelectorAll('[data-carousel-slide]');
      const titleEl = root.querySelector('[data-carousel-heading]');
      const prevBtn = root.querySelector('[data-carousel-prev]');
      const nextBtn = root.querySelector('[data-carousel-next]');
      const dotBtns = root.querySelectorAll('[data-carousel-dot]');

      const total = slideEls.length;
      if (
        !(track instanceof HTMLElement) ||
        total === 0 ||
        !(titleEl instanceof HTMLElement) ||
        !(prevBtn instanceof HTMLButtonElement) ||
        !(nextBtn instanceof HTMLButtonElement)
      ) {
        return;
      }
      const trackItemCount = track.children.length;

      const prefersReduced =
        typeof window.matchMedia === 'function' && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const intervalMs = 5000;

      const titles = Array.from(slideEls).map((el) =>
        el instanceof HTMLElement ? el.getAttribute('data-slide-title') ?? '' : '',
      );

      let activeIndex = 0;
      let trackIndex = 0;
      let isTransitioning = false;
      /** @type {number | null} */
      let timer = null;

      const getTransform = (nextTrackIndex) => `translateX(calc(-${nextTrackIndex} * 100% / ${trackItemCount}))`;

      const setControlsDisabled = (disabled) => {
        [prevBtn, nextBtn, ...dotBtns].forEach((btn) => {
          if (!(btn instanceof HTMLButtonElement)) {
            return;
          }

          btn.disabled = disabled;
          btn.setAttribute('aria-disabled', String(disabled));
        });
      };

      const syncUi = (nextActiveIndex) => {
        titleEl.textContent = titles[nextActiveIndex] ?? '';

        slideEls.forEach((el, i) => {
          if (el instanceof HTMLElement) {
            el.setAttribute('aria-hidden', i === nextActiveIndex ? 'false' : 'true');
          }
        });

        dotBtns.forEach((btn, i) => {
          if (!(btn instanceof HTMLButtonElement)) {
            return;
          }

          const active = i === nextActiveIndex;
          btn.classList.toggle('w-6', active);
          btn.classList.toggle('w-2', !active);
          btn.classList.toggle('bg-white', active);
          btn.classList.toggle('bg-white/40', !active);
          btn.classList.toggle('hover:bg-white/70', !active);
          if (active) {
            btn.setAttribute('aria-current', 'true');
          } else {
            btn.removeAttribute('aria-current');
          }
        });
      };

      const jumpToTrackIndex = (nextTrackIndex) => {
        track.style.transition = 'none';
        track.style.transform = getTransform(nextTrackIndex);
        trackIndex = nextTrackIndex;
        void track.offsetWidth;
        track.style.transition = '';
      };

      const moveTo = (nextActiveIndex, nextTrackIndex) => {
        activeIndex = ((nextActiveIndex % total) + total) % total;
        syncUi(activeIndex);

        if (prefersReduced) {
          jumpToTrackIndex(nextTrackIndex === total ? 0 : nextTrackIndex);
          return;
        }

        isTransitioning = true;
        setControlsDisabled(true);
        trackIndex = nextTrackIndex;
        track.style.transition = '';
        track.style.transform = getTransform(nextTrackIndex);
      };

      const goPrev = () => {
        if (isTransitioning) {
          return;
        }

        if (activeIndex === 0) {
          activeIndex = total - 1;
          syncUi(activeIndex);
          jumpToTrackIndex(total - 1);
          return;
        }

        moveTo(activeIndex - 1, trackIndex - 1);
      };

      const goNext = () => {
        if (isTransitioning) {
          return;
        }

        const nextActiveIndex = (activeIndex + 1) % total;
        const nextTrackIndex = trackIndex + 1;
        moveTo(nextActiveIndex, nextTrackIndex);
      };

      const stopTimer = () => {
        if (timer !== null) {
          window.clearInterval(timer);
          timer = null;
        }
      };

      const startTimer = () => {
        if (prefersReduced) {
          return;
        }

        stopTimer();
        timer = window.setInterval(goNext, intervalMs);
      };

      const restartTimer = () => {
        stopTimer();
        startTimer();
      };

      track.addEventListener('transitionend', (event) => {
        if (event.target !== track || event.propertyName !== 'transform' || !isTransitioning) {
          return;
        }

        isTransitioning = false;

        if (trackIndex === total) {
          jumpToTrackIndex(0);
        }

        setControlsDisabled(false);
      });

      prevBtn.addEventListener('click', () => {
        goPrev();
        restartTimer();
      });

      nextBtn.addEventListener('click', () => {
        goNext();
        restartTimer();
      });

      dotBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (!(btn instanceof HTMLButtonElement)) {
            return;
          }

          const raw = btn.getAttribute('data-carousel-index');
          const target = raw === null ? NaN : Number.parseInt(raw, 10);
          if (!Number.isFinite(target) || target === activeIndex || isTransitioning) {
            restartTimer();
            return;
          }

          if (activeIndex === total - 1 && target === 0) {
            moveTo(0, total);
            restartTimer();
            return;
          }

          activeIndex = target;
          syncUi(activeIndex);
          jumpToTrackIndex(target);
          restartTimer();
        });
      });

      root.addEventListener('mouseenter', stopTimer);
      root.addEventListener('mouseleave', startTimer);

      syncUi(activeIndex);
      jumpToTrackIndex(0);
      startTimer();
    })();
  </script>
</SiteLayout>
